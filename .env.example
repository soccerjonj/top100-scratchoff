# MongoDB Atlas connection string (free M0 tier)
# https://cloud.mongodb.com → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/top100?retryWrites=true&w=majority

# TMDB API key (only needed for the one-time build-lists script)
# https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Shared secret protecting the cron endpoint. Vercel auto-injects this when
# you set CRON_SECRET in project settings; locally set anything you like.
CRON_SECRET=local-dev-secret
